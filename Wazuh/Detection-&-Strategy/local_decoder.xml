

<decoders>

  <!-- ===========================================================
       1. SSH BRUTE FORCE
       =========================================================== -->

  <decoder name="custom_ssh_failed">
    <parent>sshd</parent>
    <prematch>^Failed password</prematch>
    <regex>^Failed password for( invalid user)? (\S+) from (\d+\.\d+\.\d+\.\d+) port \d+ ssh2</regex>
    <order>extra_data, user, srcip</order>
    <fts>user, srcip</fts>
  </decoder>

  <decoder name="custom_ssh_accepted">
    <parent>sshd</parent>
    <prematch>^Accepted</prematch>
    <regex>^Accepted (\S+) for (\S+) from (\d+\.\d+\.\d+\.\d+) port \d+ ssh2</regex>
    <order>extra_data, user, srcip</order>
    <fts>user, srcip</fts>
  </decoder>

  <decoder name="custom_ssh_invalid_user">
    <parent>sshd</parent>
    <prematch>^Invalid user</prematch>
    <regex>^Invalid user (\S+) from (\d+\.\d+\.\d+\.\d+) port \d+</regex>
    <order>user, srcip</order>
    <fts>user, srcip</fts>
  </decoder>

  <decoder name="custom_ssh_connection_closed">
    <parent>sshd</parent>
    <prematch>^Connection closed by authenticating user</prematch>
    <regex>^Connection closed by authenticating user (\S+) (\d+\.\d+\.\d+\.\d+) port \d+ \[preauth\]</regex>
    <order>user, srcip</order>
    <fts>user, srcip</fts>
  </decoder>


  <!-- ===========================================================
       2. SUDO / INSIDER THREAT
       =========================================================== -->

  <decoder name="custom_sudo_command">
    <program_name>sudo</program_name>
    <prematch>TTY=</prematch>
    <regex>^(\S+) : .* USER=(\S+) ; COMMAND=(.+)$</regex>
    <order>user, dstuser, extra_data</order>
    <fts>user, dstuser</fts>
  </decoder>

  <decoder name="custom_sudo_failed">
    <program_name>sudo</program_name>
    <prematch>authentication failure</prematch>
    <regex>ruser=(\S+) .* rhost=(\S*)</regex>
    <order>user, srcip</order>
    <fts>user, srcip</fts>
  </decoder>


  <!-- ===========================================================
       3. AUDITD - PROCESS EXECUTION
       =========================================================== -->

  <decoder name="custom_auditd_base">
    <program_name>auditd</program_name>
    <prematch>^type=</prematch>
  </decoder>

  <decoder name="custom_auditd_execve">
    <parent>custom_auditd_base</parent>
    <prematch>type=EXECVE</prematch>
    <regex>a0="(.+)"</regex>
    <order>extra_data</order>
  </decoder>

  <decoder name="custom_auditd_syscall">
    <parent>custom_auditd_base</parent>
    <prematch>type=SYSCALL</prematch>
    <regex>exe="([^"]+)"</regex>
    <order>extra_data</order>
  </decoder>


  <!-- ===========================================================
       4. NETWORK CONNECTIONS (netstat / ss)
       =========================================================== -->

  <decoder name="custom_netstat">
    <program_name>netstat-monitor</program_name>
    <prematch>^(tcp|udp)</prematch>
    <regex>^(tcp|udp)\s+\d+\s+\d+\s+(\d+\.\d+\.\d+\.\d+):\d+\s+(\d+\.\d+\.\d+\.\d+):\d+\s+(\S+)</regex>
    <order>extra_data, srcip, dstip, extra_data</order>
    <fts>srcip, dstip</fts>
  </decoder>


  <!-- ===========================================================
       5. WINDOWS EVENT SECURITY
       =========================================================== -->

  <decoder name="custom_win_security">
    <parent>windows</parent>
    <use_own_name>yes</use_own_name>
    <prematch>"EventID":\s*46</prematch>
  </decoder>


  <!-- ===========================================================
       6. EXFILTRATION TOOLS
       =========================================================== -->

  <decoder name="custom_exfil_tool">
    <prematch>^(curl|wget|nc|netcat|scp|rsync)</prematch>
    <regex>^(\S+)</regex>
    <order>extra_data</order>
  </decoder>


  <!-- ===========================================================
       7. WEB SERVER LOGS (Apache / Nginx)
       =========================================================== -->

  <decoder name="custom_web_access">
    <prematch>^\d+\.\d+\.\d+\.\d+</prematch>
    <regex>^(\d+\.\d+\.\d+\.\d+) \S+ \S+ \[.+\] "(\w+) (\S+) HTTP/[\d\.]+" (\d+)</regex>
    <order>srcip, method, extra_data, id</order>
    <fts>srcip</fts>
  </decoder>


  <!-- ===========================================================
       8. SERVICE ACCESS (FTP / MAIL)
       =========================================================== -->

  <decoder name="custom_service_access">
    <prematch>(from=|rhost=|rip=)</prematch>
    <regex>from[=<](\S+)[>]?.*(ip|rhost|rip)=(\d+\.\d+\.\d+\.\d+)</regex>
    <order>user, srcip</order>
    <fts>user, srcip</fts>
  </decoder>

</decoders>
